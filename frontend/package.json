{
  "name": "farpha-frontend",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/create-build-info.mjs && node scripts/create-build-manifest.mjs && node scripts/check-build-size.mjs",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "check:release": "node scripts/check-release-version.mjs",
    "check:toolchain": "node scripts/check-toolchain-compatibility.mjs",
    "check:public-entry": "node scripts/check-public-experience.mjs",
    "lint": "eslint .",
    "smoke:prod": "node scripts/smoke-production-build.mjs",
    "screenshots:capture": "node scripts/capture-product-screenshots.mjs",
    "test": "vitest run",
    "validate": "node scripts/run-validation.mjs",
    "verify:pwa": "node scripts/verify-pwa.mjs",
    "verify:brand": "node scripts/check-brand-consistency.mjs",
    "verify:maturity": "node scripts/check-module-maturity.mjs",
    "verify:media": "node scripts/check-documentation-media.mjs",
    "verify:repository": "node scripts/check-repository-integrity.mjs",
    "verify:security": "node scripts/check-production-security.mjs",
    "verify:dist": "node scripts/verify-build-manifest.mjs",
    "verify:docs": "node scripts/check-documentation-links.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@supabase/supabase-js": "^2.110.8",
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/react-query": "^5.101.4",
    "@tmcw/togeojson": "^7.1.2",
    "@turf/turf": "^7.3.5",
    "@types/maplibre-gl": "^1.13.2",
    "@watergis/maplibre-gl-terradraw": "^1.15.0",
    "axios": "^1.18.1",
    "fflate": "^0.8.3",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.26.0",
    "maplibre-gl": "^5.24.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-hook-form": "^7.82.0",
    "react-router-dom": "^7.18.1",
    "shpjs": "^6.2.0",
    "tailwindcss": "^4.3.2",
    "terra-draw": "^1.32.2",
    "terra-draw-maplibre-gl-adapter": "^1.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.0"
  }
}
